# Caseware Cloud OAuth credentials — per region
# CA = Canadian partner cloud (ca.cwcloudpartner.com)
# US = US partner cloud (us.cwcloudpartner.com)
CW_CA_CLIENT_ID=
CW_CA_CLIENT_SECRET=
CW_US_CLIENT_ID=
CW_US_CLIENT_SECRET=

# Cookie fallback — used if OAuth client credentials are not present.
# Paste a serialized cookie string captured from a browser session.
CW_COOKIES=
